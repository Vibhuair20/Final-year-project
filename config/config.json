{
    "version": "1.0",
    "description": "Data Acquisition Layer Configuration",
    "audio_settings": {
        "supported_formats": [
            ".wav",
            ".mp3"
        ],
        "max_file_size_mb": 500,
        "min_duration_seconds": 0.1,
        "max_duration_seconds": 3600
    },
    "paths": {
        "input_dir": "data/input",
        "output_dir": "data/output",
        "archive_dir": "data/archive"
    },
    "processing": {
        "timezone": "+05:30",
        "auto_archive": false,
        "generate_checksum": true,
        "extract_extended_metadata": false
    },
    "logging": {
        "level": "INFO",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        "file": "logs/dal.log"
    },
    "future_extensions": {
        "voip_stream_support": {
            "enabled": false,
            "buffer_size_seconds": 30,
            "chunk_duration_seconds": 5,
            "protocols": [
                "SIP",
                "RTP"
            ]
        },
        "database": {
            "enabled": false,
            "type": "sqlite",
            "path": "data/metadata.db"
        },
        "api": {
            "enabled": false,
            "host": "0.0.0.0",
            "port": 8000
        }
    }
}